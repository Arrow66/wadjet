# Copy to server/.env for local development.
# On Render, set these in the dashboard (NODE_ENV=production is set by render.yaml).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
MOCK_MODE=false
NODE_ENV=development

GEMINI_MAX_CONCURRENT=1
GEMINI_MIN_DELAY_MS=4000
PORT=3000

# Optional — Render sets RENDER_EXTERNAL_URL automatically
# FRONTEND_URL=https://your-app.onrender.com
# PARTNER_API_KEY=
